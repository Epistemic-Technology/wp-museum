# URL for the dev WordPress site.
# Must match what the browser uses, so WordPress doesn't redirect.
# Examples:
#   http://localhost:8080
#   http://myserver.tailnet-xxxx.ts.net:8080
WP_HOME=http://localhost:8080

# URL for the test WordPress site, used by wp core install.
# Default (http://nginx-test) works inside the compose network for Playwright.
# Override if you want to browse the test site from your laptop.
TEST_SITE_URL=http://nginx-test

# Host ports. Change if 8080/8443/3306 are taken.
DEV_HTTP_PORT=8080
DEV_HTTPS_PORT=8443
TEST_HTTP_PORT=8081
TEST_HTTPS_PORT=8444
DB_PORT=3306

# Xdebug. Leave blank to disable; set XDEBUG_MODE=debug to enable.
XDEBUG_MODE=
XDEBUG_CONFIG=
